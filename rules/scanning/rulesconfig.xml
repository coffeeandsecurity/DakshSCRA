<root>
    <rule>
        <platform>dotnet</platform>
        <path>/dotnet/dotnet.xml</path>
        <platform_ftypes>*.aspx, *.cs, *.vb, *.asax, *.asp, *.sln, *.svc, *.cshtml, *.rdl, *.edmx</platform_ftypes>
        <project_config_ftypes>*.config, web.config, app.config, machine.config</project_config_ftypes>
        <common_ftypes>*.config, *.sql, *.xml, *.json, *.resx, *.settings, *.log</common_ftypes>
    </rule>
    <rule>
        <platform>php</platform>
        <path>/php/php.xml</path>
        <platform_ftypes>*.php</platform_ftypes>
        <project_config_ftypes>php.ini, .htaccess, composer.json, composer.lock</project_config_ftypes>
        <common_ftypes>*.ini, *.txt, *.config, *.xml, *.lock, .htaccess, *.log, *.json</common_ftypes>
    </rule>
    <rule>
        <platform>java</platform>
        <path>/java/java.xml</path>
        <platform_ftypes>*.java, *.jsp</platform_ftypes>
        <project_config_ftypes>pom.xml, settings.xml, application.properties, application.yml</project_config_ftypes>
        <common_ftypes>*.xml, *.properties, *.config, *.json, *.log, *.yml, *.yaml</common_ftypes>
    </rule>
    <rule>
        <platform>javascript</platform>
        <path>/javascript/javascript.xml</path>
        <platform_ftypes>*.js, *.ts</platform_ftypes>
        <project_config_ftypes>package.json, package-lock.json, webpack.config.js, tsconfig.json</project_config_ftypes>
        <common_ftypes>*.json, *.config, *.lock, *.yml, *.yaml, *.log</common_ftypes>
    </rule>
    <rule>
        <platform>kotlin</platform>
        <path>/kotlin/kotlin.xml</path>
        <platform_ftypes>*.kt</platform_ftypes>
        <project_config_ftypes>build.gradle, settings.gradle, gradle.properties</project_config_ftypes>
        <common_ftypes>*.java, *.xml, *.json, *.gradle, *.properties, *.log</common_ftypes>
    </rule>
    <rule>
        <platform>python</platform>
        <path>/python/python.xml</path>
        <platform_ftypes>*.py</platform_ftypes>
        <project_config_ftypes>requirements.txt, setup.py, Pipfile, Pipfile.lock, manage.py, settings.py, wsgi.py, asgi.py, pyproject.toml</project_config_ftypes>
        <common_ftypes>*.yml, *.yaml, *.config, *.xml, *.json, *.log, *.txt, *.ini, .env, *.cfg</common_ftypes>
    </rule>
    <rule>
        <platform>go</platform>
        <path>/golang/go.xml</path>
        <platform_ftypes>*.go</platform_ftypes>
        <project_config_ftypes>go.mod, go.sum</project_config_ftypes>
        <common_ftypes>*.mod, *.sum, *.yaml, *.yml, *.json, *.ini, *.cfg, *.txt, *.log</common_ftypes>
    </rule>
    <rule>
        <platform>c</platform>
        <path>/c/c.xml</path>
        <platform_ftypes>*.c, *.cpp, *.h</platform_ftypes>
        <project_config_ftypes>Makefile, configure.ac, config.h</project_config_ftypes>
        <common_ftypes>Makefile, *.config, *.ini, *.json, *.xml, *.log</common_ftypes>
    </rule>
    <rule>
        <platform>cpp</platform>
        <path>/cpp/cpp.xml</path>
        <platform_ftypes>*.cpp, *.cc, *.cxx, *.hpp, *.hxx</platform_ftypes>
        <project_config_ftypes>Makefile, CMakeLists.txt, *.vcxproj, *.props</project_config_ftypes>
        <common_ftypes>*.h, Makefile, CMakeLists.txt, *.vcxproj, *.props, *.config, *.json, *.log</common_ftypes>
    </rule>
    <rule>
        <platform>android</platform>
        <path>/mobile/android/android.xml</path>
        <platform_ftypes>AndroidManifest.xml, build.gradle, proguard-rules.pro</platform_ftypes>
        <project_config_ftypes>AndroidManifest.xml, build.gradle, proguard-rules.pro</project_config_ftypes>
        <common_ftypes>*.xml, *.json, *.gradle, *.properties, *.log</common_ftypes>
    </rule>
    <rule>
        <platform>ios</platform>
        <path>/mobile/ios/ios.xml</path>
        <platform_ftypes>*.swift, *.m, *.mm, *.h, Info.plist, *.entitlements, Podfile, project.pbxproj</platform_ftypes>
        <project_config_ftypes>Info.plist, *.entitlements, Podfile, project.pbxproj, *.xcodeproj</project_config_ftypes>
        <common_ftypes>*.plist, *.json, *.mobileprovision, *.xcconfig, *.log</common_ftypes>
    </rule>
    <rule>
        <platform>reactnative</platform>
        <path>/mobile/xplat/reactnative/reactnative.xml</path>
        <platform_ftypes>*.js, *.jsx, *.ts, *.tsx, app.json, metro.config.js, babel.config.js</platform_ftypes>
        <project_config_ftypes>package.json, app.json, metro.config.js, babel.config.js</project_config_ftypes>
        <common_ftypes>*.json, *.config.js, *.ts, *.js, *.yml, *.yaml, *.log</common_ftypes>
    </rule>
    <rule>
        <platform>flutter</platform>
        <path>/mobile/xplat/flutter/flutter.xml</path>
        <platform_ftypes>*.dart, pubspec.yaml, AndroidManifest.xml, Info.plist</platform_ftypes>
        <project_config_ftypes>pubspec.yaml, analysis_options.yaml, AndroidManifest.xml, Info.plist</project_config_ftypes>
        <common_ftypes>*.dart, *.yaml, *.yml, *.json, *.plist, *.gradle, *.log</common_ftypes>
    </rule>
    <rule>
        <platform>xamarin</platform>
        <path>/mobile/xplat/xamarin/xamarin.xml</path>
        <platform_ftypes>*.cs, *.csproj, AndroidManifest.xml, Info.plist, Entitlements.plist</platform_ftypes>
        <project_config_ftypes>*.csproj, *.sln, AndroidManifest.xml, Info.plist, Entitlements.plist</project_config_ftypes>
        <common_ftypes>*.config, *.plist, *.json, *.xml, *.resx, *.log</common_ftypes>
    </rule>
    <rule>
        <platform>ionic</platform>
        <path>/mobile/xplat/ionic/ionic.xml</path>
        <platform_ftypes>*.ts, *.js, *.html, capacitor.config.json, capacitor.config.ts, ionic.config.json</platform_ftypes>
        <project_config_ftypes>package.json, capacitor.config.json, capacitor.config.ts, ionic.config.json</project_config_ftypes>
        <common_ftypes>*.json, *.yaml, *.yml, *.xml, *.gradle, *.plist, *.log</common_ftypes>
    </rule>
    <rule>
        <platform>nativescript</platform>
        <path>/mobile/xplat/nativescript/nativescript.xml</path>
        <platform_ftypes>*.js, *.ts, app.gradle, AndroidManifest.xml, Info.plist</platform_ftypes>
        <project_config_ftypes>package.json, app.gradle, webpack.config.js, nsconfig.json</project_config_ftypes>
        <common_ftypes>*.json, *.ts, *.js, *.xml, *.gradle, *.plist, *.log</common_ftypes>
    </rule>
    <rule>
        <platform>cordova</platform>
        <path>/mobile/xplat/cordova/cordova.xml</path>
        <platform_ftypes>config.xml, *.js, *.ts, *.html</platform_ftypes>
        <project_config_ftypes>config.xml, package.json, cordova-plugin-*.xml</project_config_ftypes>
        <common_ftypes>*.json, *.xml, *.plist, *.gradle, *.properties, *.log</common_ftypes>
    </rule>
    <rule>
        <platform>bash</platform>
        <path>/bash/bash.xml</path>
        <platform_ftypes>*.sh, *.bash, *.bsh</platform_ftypes>
        <project_config_ftypes>.bashrc, .bash_profile, .profile, .bash_aliases</project_config_ftypes>
        <common_ftypes>*.sh, *.bash, *.env, *.conf, *.log</common_ftypes>
    </rule>
    <rule>
        <platform>powershell</platform>
        <path>/powershell/powershell.xml</path>
        <platform_ftypes>*.ps1, *.psm1, *.psd1, *.ps1xml</platform_ftypes>
        <project_config_ftypes>*.psd1, *.psm1, PSScriptAnalyzerSettings.psd1</project_config_ftypes>
        <common_ftypes>*.ps1, *.xml, *.json, *.csv, *.log, *.env</common_ftypes>
    </rule>
    <rule>
        <platform>dockerfile</platform>
        <path>/dockerfile/dockerfile.xml</path>
        <platform_ftypes>Dockerfile, Dockerfile.*, *.dockerfile</platform_ftypes>
        <project_config_ftypes>Dockerfile, docker-compose.yml, docker-compose.yaml, .dockerignore</project_config_ftypes>
        <common_ftypes>Dockerfile, docker-compose.yml, docker-compose.yaml, *.env, *.conf, *.sh</common_ftypes>
    </rule>
    <rule>
        <platform>terraform</platform>
        <path>/terraform/terraform.xml</path>
        <platform_ftypes>*.tf, *.tfvars, *.tf.json</platform_ftypes>
        <project_config_ftypes>*.tf, *.tfvars, terraform.tfvars, *.tfstate, backend.tf, variables.tf, outputs.tf</project_config_ftypes>
        <common_ftypes>*.tf, *.tfvars, *.json, *.yaml, *.yml, *.env, *.log</common_ftypes>
    </rule>
    <rule>
        <platform>kubernetes</platform>
        <path>/kubernetes/kubernetes.xml</path>
        <platform_ftypes>*.yaml, *.yml</platform_ftypes>
        <project_config_ftypes>*.yaml, *.yml, kustomization.yaml, Chart.yaml, values.yaml</project_config_ftypes>
        <common_ftypes>*.yaml, *.yml, *.json, *.env, *.conf, *.log</common_ftypes>
    </rule>
    <rule>
        <platform>ruby</platform>
        <path>/ruby/ruby.xml</path>
        <platform_ftypes>*.rb</platform_ftypes>
        <project_config_ftypes>Gemfile, Gemfile.lock, Rakefile, config.ru</project_config_ftypes>
        <common_ftypes>*.yml, *.yaml, *.erb, *.json, *.log</common_ftypes>
    </rule>
    <rule>
        <platform>rust</platform>
        <path>/rust/rust.xml</path>
        <platform_ftypes>*.rs</platform_ftypes>
        <project_config_ftypes>Cargo.toml, Cargo.lock</project_config_ftypes>
        <common_ftypes>*.toml, *.json, *.env, *.log</common_ftypes>
    </rule>
    <rule>
        <platform>common</platform>
        <path>/common.xml</path>
        <platform_ftypes>*.aspx, *.cs, *.vb, *.asax, *.asp, *.sln, *.svc, *.cshtml, *.rdl, *.edmx, *.php, *.java, *.jsp, *.js, *.ts, *.py, *.kt, *.go, *.c, *.cpp, *.h, *.cc, *.cxx, *.hpp, *.hxx, *.groovy, *.carbon, *.rb, *.rs, *.swift, *.m, *.mm, *.dart, *.sql, *.psql, *.db, *.env</platform_ftypes>
        <project_config_ftypes>*.config, web.config, app.config, machine.config, php.ini, .htaccess, composer.json, composer.lock, pom.xml, settings.xml, application.properties, application.yml, package.json, package-lock.json, webpack.config.js, tsconfig.json, build.gradle, settings.gradle, gradle.properties, requirements.txt, setup.py, Pipfile, Pipfile.lock, manage.py, settings.py, wsgi.py, asgi.py, pyproject.toml, go.mod, go.sum, Makefile, configure.ac, config.h, CMakeLists.txt, *.vcxproj, *.props, AndroidManifest.xml, proguard-rules.pro, Info.plist, Podfile, project.pbxproj, pubspec.yaml, Cargo.toml, Gemfile</project_config_ftypes>
        <common_ftypes>*.conf, *.properties, *.env, *.resx, *.settings, *.json, *.lock, *.yml, *.yaml, *.xml, *.log, *.ini, *.txt, .env, *.cfg, *.bash, *.sh, *.ps1, *.bat, *.cmd, *.mod, *.sum</common_ftypes>
    </rule>

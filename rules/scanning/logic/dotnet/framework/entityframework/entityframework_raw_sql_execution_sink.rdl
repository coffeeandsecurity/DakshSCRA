VERSION 1
WHEN PRESENT FromSqlRaw\(|ExecuteSqlRaw\(|SqlQueryRaw\(
WHEN EXPR MISSING:FromSqlInterpolated|SqlParameter|parameterized|\?\s*,|\{[0-9]\}.*params

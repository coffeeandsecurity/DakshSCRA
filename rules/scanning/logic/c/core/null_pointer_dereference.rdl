VERSION 1
WHEN PRESENT (\w+)\s*=\s*NULL\s*;\s*\w+\s*\(.*\1.*\)
WHEN EXPR MISSING:if\s*\(.*!=\s*NULL\)|if\s*\(.*!=\s*nullptr\)|assert\s*\(|NULL\s*!=|nullptr\s*!=

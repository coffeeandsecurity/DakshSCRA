{
  "Frontend": [
    {"name": "JavaScript", "regex": "\\.(js|mjs|cjs)$|\\bjavascript\\b", "regexFlag": "0", "fileExtensions": [".js", ".mjs", ".cjs"]},
    {"name": "TypeScript", "regex": "\\.(ts|tsx)$|\\btypescript\\b", "regexFlag": "0", "fileExtensions": [".ts", ".tsx"]},
    {"name": "React", "regex": "\\bfrom\\s+['\"]react['\"]|\\breact-dom\\b|\\bjsx\\b", "regexFlag": "1", "fileExtensions": [".js", ".jsx", ".ts", ".tsx", ".json"]},
    {"name": "Next.js", "regex": "\\bnext\\b|next\\.config\\.(js|mjs|ts)|\\bnext/router\\b", "regexFlag": "1", "fileExtensions": [".js", ".jsx", ".ts", ".tsx", ".json", "*"]},
    {"name": "Vue.js", "regex": "\\bfrom\\s+['\"]vue['\"]|createApp\\(|\\.vue$", "regexFlag": "1", "fileExtensions": [".vue", ".js", ".ts", ".json"]},
    {"name": "Nuxt", "regex": "\\bnuxt\\b|nuxt\\.config\\.(js|ts)", "regexFlag": "1", "fileExtensions": [".js", ".ts", ".json", "*"]},
    {"name": "Angular", "regex": "@angular/|angular\\.json|\\bNgModule\\b", "regexFlag": "1", "fileExtensions": [".ts", ".html", ".json", "*"]},
    {"name": "Svelte", "regex": "\\bsvelte\\b|svelte\\.config\\.js", "regexFlag": "1", "fileExtensions": [".svelte", ".js", ".ts", ".json", "*"]},
    {"name": "Astro", "regex": "\\bastro\\b|astro\\.config\\.(mjs|ts)", "regexFlag": "1", "fileExtensions": [".astro", ".js", ".ts", ".json", "*"]},
    {"name": "Ember.js", "regex": "\\bember\\b|ember-cli-build\\.js", "regexFlag": "1", "fileExtensions": [".js", ".ts", ".json", "*"]},
    {"name": "Backbone.js", "regex": "\\bbackbone\\b", "regexFlag": "1", "fileExtensions": [".js", ".ts", ".json"]}
  ],
  "Backend": [
    {"name": "Node.js", "regex": "\\b(express|koa|hapi|fastify|nestjs|nest\\s*\\()\\b|package\\.json", "regexFlag": "1", "fileExtensions": [".js", ".ts", ".json", "*"]},
    {"name": "PHP", "regex": "<\\?php|composer\\.json", "regexFlag": "1", "fileExtensions": [".php", ".inc", ".json", "*"]},
    {"name": ".NET", "regex": "using\\s+System|<Project\\s+Sdk=|\\.csproj$|\\.sln$", "regexFlag": "1", "fileExtensions": [".cs", ".csproj", ".sln", ".config", "*"]},
    {"name": "Ruby", "regex": "\\bruby\\b|Gemfile|\\.rb$", "regexFlag": "1", "fileExtensions": [".rb", "*"]},
    {"name": "Java", "regex": "\\bimport\\s+java\\.|pom\\.xml|build\\.gradle|build\\.gradle\\.kts", "regexFlag": "1", "fileExtensions": [".java", ".xml", ".gradle", ".kts", "*"]},
    {"name": "Python", "regex": "\\bimport\\s+|requirements\\.txt|pyproject\\.toml|setup\\.py|Pipfile", "regexFlag": "1", "fileExtensions": [".py", ".txt", ".toml", "*"]},
    {"name": "Rust", "regex": "\\buse\\s+|Cargo\\.toml", "regexFlag": "1", "fileExtensions": [".rs", ".toml", "*"]},
    {"name": "Go", "regex": "\\bpackage\\s+main\\b|\\bimport\\s+\\(|go\\.mod", "regexFlag": "1", "fileExtensions": [".go", "*"]},
    {"name": "C#", "regex": "using\\s+System\\.|\\.cs$", "regexFlag": "1", "fileExtensions": [".cs", "*"]},
    {"name": "Scala", "regex": "\\bimport\\s+scala\\.|build\\.sbt", "regexFlag": "1", "fileExtensions": [".scala", ".sbt", "*"]},
    {"name": "Perl", "regex": "#!/usr/bin/perl|\\buse\\s+strict\\b", "regexFlag": "1", "fileExtensions": [".pl", "*"]},
    {"name": "Haskell", "regex": "\\bmodule\\s+\\w+|stack\\.yaml|cabal", "regexFlag": "1", "fileExtensions": [".hs", ".yaml", "*"]},
    {"name": "Kotlin", "regex": "\\bimport\\s+kotlin\\.|\\.kt$", "regexFlag": "1", "fileExtensions": [".kt", ".kts"]},
    {"name": "Elixir", "regex": "\\bdefmodule\\b|mix\\.exs", "regexFlag": "1", "fileExtensions": [".ex", ".exs", "*"]},
    {"name": "Lua", "regex": "\\brequire\\s*\\(|\\.lua$", "regexFlag": "1", "fileExtensions": [".lua"]},
    {"name": "Groovy", "regex": "\\bimport\\s+groovy\\.|\\.groovy$", "regexFlag": "1", "fileExtensions": [".groovy"]},
    {"name": "Dart", "regex": "\\bimport\\s+['\"]package:", "regexFlag": "1", "fileExtensions": [".dart"]}
  ],
  "Mobile Platforms": [
    {"name": "Android", "regex": "AndroidManifest\\.xml|android\\s*\\{|com\\.android\\.(application|library)|androidx\\.", "regexFlag": "1", "fileExtensions": [".xml", ".gradle", ".kts", ".java", ".kt", "*"]},
    {"name": "iOS", "regex": "\\.xcodeproj|\\.xcworkspace|Info\\.plist|Podfile|UIApplication|UIKit", "regexFlag": "1", "fileExtensions": [".swift", ".m", ".mm", ".plist", "*"]},
    {"name": "React Native", "regex": "react-native|@react-native|app\\.json", "regexFlag": "1", "fileExtensions": [".js", ".jsx", ".ts", ".tsx", ".json", "*"]},
    {"name": "Flutter", "regex": "\\bflutter\\b|pubspec\\.yaml|MaterialApp\\(|CupertinoApp\\(", "regexFlag": "1", "fileExtensions": [".dart", ".yaml", "*"]},
    {"name": "Ionic", "regex": "@ionic/|ionic\\.config\\.json|from\\s+['\\\"]ionic", "regexFlag": "1", "fileExtensions": [".js", ".ts", ".html", ".json", "*"]},
    {"name": "Xamarin", "regex": "Xamarin\\.|monoandroid|xamarinios", "regexFlag": "1", "fileExtensions": [".cs", ".csproj", "*"]},
    {"name": "NativeScript", "regex": "nativescript", "regexFlag": "1", "fileExtensions": [".js", ".ts", ".json", "*"]},
    {"name": "Cordova", "regex": "cordova|config\\.xml|cordova\\.js", "regexFlag": "1", "fileExtensions": [".js", ".xml", ".json", "*"]},
    {"name": "Capacitor", "regex": "@capacitor/|capacitor\\.config\\.(json|ts)", "regexFlag": "1", "fileExtensions": [".ts", ".json", "*"]},
    {"name": "Kotlin Multiplatform", "regex": "kotlin\\(\\\"multiplatform\\\"\\)|kotlin-multiplatform", "regexFlag": "1", "fileExtensions": [".kts", ".gradle", "*"]}
  ],
  "Database": [
    {"name": "MySQL", "regex": "mysql|pymysql|mysql2|jdbc:mysql", "regexFlag": "1", "fileExtensions": [".sql", ".py", ".js", ".ts", ".java", ".php", ".yml", ".yaml", ".json"]},
    {"name": "PostgreSQL", "regex": "postgres|psycopg2|pg\\b|jdbc:postgresql", "regexFlag": "1", "fileExtensions": [".sql", ".py", ".js", ".ts", ".java", ".php", ".yml", ".yaml", ".json"]},
    {"name": "MongoDB", "regex": "mongodb|mongoose|pymongo", "regexFlag": "1", "fileExtensions": [".js", ".ts", ".py", ".java", ".json", ".yml", ".yaml"]},
    {"name": "SQLite", "regex": "sqlite3|sqlite", "regexFlag": "1", "fileExtensions": [".py", ".js", ".ts", ".java", ".php", ".sql", ".db"]},
    {"name": "Redis", "regex": "redis|ioredis|lettuce|jedis", "regexFlag": "1", "fileExtensions": [".py", ".js", ".ts", ".java", ".php", ".rb", ".yml", ".yaml", ".json"]},
    {"name": "MariaDB", "regex": "mariadb", "regexFlag": "1", "fileExtensions": [".sql", ".yml", ".yaml", ".json"]},
    {"name": "Oracle", "regex": "oracle|cx_Oracle|oci8|jdbc:oracle", "regexFlag": "1", "fileExtensions": [".sql", ".py", ".java", ".php", ".yml", ".yaml", ".json"]},
    {"name": "SQL Server", "regex": "sqlserver|mssql|jdbc:sqlserver", "regexFlag": "1", "fileExtensions": [".sql", ".py", ".js", ".ts", ".java", ".yml", ".yaml", ".json"]}
  ],
  "Shell Scripts": [
    {"name": "Bash", "regex": "#!/bin/bash|#!/usr/bin/env bash", "regexFlag": "1", "fileExtensions": [".sh", ".bash", ".bsh"]},
    {"name": "Zsh", "regex": "#!/bin/zsh|#!/usr/bin/env zsh", "regexFlag": "1", "fileExtensions": [".zsh"]},
    {"name": "PowerShell", "regex": "\\bFunction\\b|\\bparam\\(|\\.ps1$", "regexFlag": "1", "fileExtensions": [".ps1", ".psm1", ".psd1"]},
    {"name": "Batch", "regex": "@echo\\s+off|\\.bat$", "regexFlag": "1", "fileExtensions": [".bat", ".cmd"]}
  ],
  "Infrastructure": [
    {"name": "Docker", "regex": "^FROM\\s+\\S+|^RUN\\s+|^COPY\\s+|^EXPOSE\\s+|docker-compose", "regexFlag": "1", "fileExtensions": ["Dockerfile", ".dockerfile", ".yml", ".yaml"]},
    {"name": "Terraform", "regex": "resource\\s+\"\\w+\"|provider\\s+\"\\w+\"|terraform\\s+\\{|variable\\s+\"\\w+\"", "regexFlag": "1", "fileExtensions": [".tf", ".tfvars"]},
    {"name": "Kubernetes", "regex": "apiVersion:\\s*\\w+|kind:\\s*(Pod|Deployment|Service|ConfigMap|Secret|Ingress|StatefulSet|DaemonSet|Job|CronJob|ClusterRole|RoleBinding)", "regexFlag": "1", "fileExtensions": [".yaml", ".yml"]},
    {"name": "Helm", "regex": "\\{\\{\\s*\\.Values\\.|helm\\.sh/chart|apiVersion:\\s*v2", "regexFlag": "1", "fileExtensions": [".yaml", ".yml", ".tpl"]}
  ],
  "System Programs": [
    {"name": "C", "regex": "#include\\s+<stdio\\.h>|\\.c$", "regexFlag": "1", "fileExtensions": [".c", ".h"]},
    {"name": "C++", "regex": "#include\\s+<iostream>|\\.cpp$|\\.hpp$", "regexFlag": "1", "fileExtensions": [".cpp", ".cc", ".cxx", ".hpp", ".hh", ".hxx"]},
    {"name": "Rust", "regex": "\\bfn\\s+main\\s*\\(|Cargo\\.toml", "regexFlag": "1", "fileExtensions": [".rs", ".toml", "*"]},
    {"name": "Go", "regex": "\\bpackage\\s+main\\b|go\\.mod", "regexFlag": "1", "fileExtensions": [".go", "*"]}
  ]
}

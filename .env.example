# Copy to .env and adjust for your host.
# docker compose will consume these values automatically.

POSTGRES_USER=daksh
POSTGRES_PASSWORD=secret
POSTGRES_DB=dakshscra

# Primary source mount inside containers
DAKSH_SCAN_ROOT=/mnt/c

# Generic host root mount
DAKSH_HOST_MOUNT=/mnt
# This is mounted to both /host and /mnt in containers

# Optional dedicated host drive mounts
DAKSH_HOST_C=/mnt/c
DAKSH_HOST_D=/mnt/d

# Docker Desktop VM host mount (Windows/macOS)
DAKSH_DESKTOP_MOUNT=/run/desktop/mnt/host

# Directories exposed to web browser modal (comma-separated)
DAKSH_BROWSE_ROOTS=/app,/scan-targets,/host,/host/c,/host/d,/run/desktop/mnt/host,/mnt,/Volumes,/Users

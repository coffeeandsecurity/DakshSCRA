VERSION 1
WHEN PRESENT xml_parser_create\s*\(|XMLReader::open\s*\(|new\s+XMLReader\s*\(
WHEN EXPR MISSING:libxml_disable_entity_loader|XML_OPTION_SKIP_WHITE|LIBXML_NOENT\s*=\s*0
